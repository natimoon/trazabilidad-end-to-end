      <ResultCollector guiclass="SimpleDataWriter" testclass="ResultCollector" testname="Resultados en CSV">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <time>true</time>
